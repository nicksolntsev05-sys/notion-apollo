PORT=3000

# Notion Integration Token (my-integrations -> Internal Integration Token)
NOTION_TOKEN=ntn_xxxxxxxxxxxxxxxxxxxxxxxx

# Apollo API key (Settings -> API)
APOLLO_API_KEY=xxxxxxxxxxxxxxxxxxxxxxxx

# Придумай свою длинную случайную строку — она защищает твой webhook-эндпоинт
# от посторонних запросов. Используй её же в URL кнопки Notion как ?secret=...
WEBHOOK_SECRET=change-me-to-a-random-long-string

# Названия колонок в твоей Notion-таблице (если отличаются от дефолтных — поменяй)
NOTION_LINKEDIN_PROPERTY=Contact Linkedin page
NOTION_EMAIL_PROPERTY=Contacts Email
NOTION_STATUS_PROPERTY=Enrich Status
